{
  "version": 2,
  "buildCommand": "vite build && esbuild server-fn.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/app-bundle.js",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.ts" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
